# =============================================================================
# Meshtastic MQTT Integration - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
#
# See docs/developer-guide.md for full setup instructions.

# -----------------------------------------------------------------------------
# MQTT Broker Configuration
# -----------------------------------------------------------------------------
# Hostname or IP address of the Meshtastic MQTT broker
MQTT_BROKER_HOST=mqtt.meshtastic.org

# MQTT broker port (default: 1883, TLS: 8883)
MQTT_BROKER_PORT=1883

# MQTT broker credentials (optional — leave blank for anonymous access)
MQTT_USERNAME=meshdev
MQTT_PASSWORD=large4cats

# Enable TLS/SSL for the MQTT connection (true/false)
MQTT_USE_TLS=false

# -----------------------------------------------------------------------------
# MQTT Topic Configuration
# -----------------------------------------------------------------------------
# MQTT topic pattern to subscribe to (supports MQTT wildcards: +, #)
# Standard format: msh/{region}/2/e/{channel}/{gateway_id}
MQTT_TOPIC_PATTERN=msh/US/2/e/#

# Meshtastic region code used for topic construction
MQTT_REGION=US

# -----------------------------------------------------------------------------
# Channel Encryption Keys (base64-encoded)
# -----------------------------------------------------------------------------
# Each channel requires a base64-encoded AES key for decryption.
# The special value "AQ==" (single byte 0x01) maps to the default Meshtastic key.
# Keys shorter than 16 bytes are zero-padded to 16; 17-31 bytes padded to 32;
# keys longer than 32 bytes are truncated to 32.

# Default Meshtastic key for the LongFast channel
MQTT_CHANNEL_KEY_LONGFAST=AQ==

# Add additional channels as needed:
# MQTT_CHANNEL_KEY_MYCHANNEL=<base64-encoded-key>

# -----------------------------------------------------------------------------
# Home Assistant
# -----------------------------------------------------------------------------
# Path to the Home Assistant configuration directory.
# Only needed for standalone development/testing outside of HA.
HASS_CONFIG_DIR=./config

# -----------------------------------------------------------------------------
# Testing (Hypothesis Property-Based Testing)
# -----------------------------------------------------------------------------
# Hypothesis test profile controlling the number of generated examples.
# Profiles are registered in tests/conftest.py.
#   dev  — 100 examples (fast local iteration)
#   ci   — 200 examples (thorough, used in CI pipeline)
HYPOTHESIS_PROFILE=dev

# Minimum code coverage percentage required for tests to pass.
# The CI pipeline enforces this threshold via pytest-cov --cov-fail-under.
COVERAGE_THRESHOLD=80

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Python logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
