{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Home Assistant (with Meshtastic)",
            "type": "debugpy",
            "request": "launch",
            "module": "homeassistant",
            "args": [
                "--config",
                "${workspaceFolder}/config"
            ],
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-x",
                "-vv"
            ],
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Current Test File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-x",
                "-vv"
            ],
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Attach to Running Process",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": false
        }
    ]
}
